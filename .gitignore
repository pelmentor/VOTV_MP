Thumbs.db
ehthumbs.db
.DS_Store
desktop.ini

# ===== Temporary / log =====
*.log
*.tmp
*.bak
*.swp
*~

# ===== Per-machine launcher / helper scripts (local convenience) =====
# 2026-06-02 (user request): untrack the root LAN-test launchers + play helpers
# (mp_*.bat, play-coop.bat, shot.bat, stop-coop.bat). They are per-machine
# convenience scripts (window titles, local paths), not collaborative source.
# `git rm --cached` runs in the same commit that adds this rule. The
# `!Game/coop-*.bat` allow-list below still overrides this for those.
*.bat

# ===== Claude Code per-machine config (MCP paths etc.) =====
.claude/
# User-decision 2026-05-25 NIGHT: CLAUDE.md is a per-user dev notebook
# (Claude Code reads it as project context) and is now treated as local-only.
# Existing tracked copy is untracked via `git rm --cached CLAUDE.md` in the
# same commit that adds this line.
CLAUDE.md

# ===== Allow-list (override broad bans for our own outputs) =====
!src/**/*.dll
!tools/**/*.exe
!Game/coop-*.bat

# Agent-side test screenshots (capture-window.ps1 / shot.bat output)
tools/shots/
research/npctest_shots/
research/menu_shots/
research/clumpshot_shots/
research/clumpvis_shots/
