+            "every 5 s x20", useFn->load(), lookOff->load());
+
+    // Sim-grab the nearest pile every 5 s for ~100 s. OnPileGrabPre self-gates on connected(), so any
+    // grab fired before the client connects simply no-ops; once connected, each grab drives the real sync.
+    for (int i = 0; i < 20; ++i) {
+        void* fn = useFn->load();
+        const int off = lookOff->load();
+        GT::Post([fn, off, roleStr, i] {
+            void* player = coop::players::Registry::Get().Local();
+            if (!player || !R::IsLive(player)) return;
+            const ue_wrap::FVector pos = ue_wrap::engine::GetActorLocation(player);
+            float d = -1.f;
+            // Target a pile this peer can actually SYNC. HOST: its piles carry forward-tracker eids, so the
+            // nearest chipPile works (symptom A). CLIENT: OnPileGrabPre relays only a pile BOUND to a
+            // host-range MIRROR eid -- so target the nearest BOUND chipPile (a shared host pile), skipping the
+            // client's own unbound spawn-area piles which correctly do NOT relay (symptom B).
+            void* pile = nullptr;
+            if (std::string(roleStr) == "CLIENT") {
+                float bestD2 = 30000.f * 30000.f;  // search up to ~300 m for a bound pile
+                const int32_t nObj = R::NumObjects();
+                for (int32_t k = 0; k < nObj; ++k) {
+                    void* o = R::ObjectAt(k);
+                    if (!o || !R::IsLive(o) || !ue_wrap::prop::IsChipPile(o)) continue;
+                    const coop::element::ElementId eid = coop::remote_prop::ResolveMirrorEidByActor(o);
+                    if (eid == coop::element::kInvalidId || eid == 0u ||
+                        eid >= coop::element::kHostRangeSize) continue;
+                    const ue_wrap::FVector l = ue_wrap::engine::GetActorLocation(o);
+                    const float dx = l.X - pos.X, dy = l.Y - pos.Y, dz = l.Z - pos.Z;
+                    const float dd = dx * dx + dy * dy + dz * dz;
+                    if (dd < bestD2) { bestD2 = dd; pile = o; d = std::sqrt(dd); }
+                }
+            } else {
+                pile = ue_wrap::prop::FindNearestChipPile(pos, 30000.f, &d);
+            }
+            if (!pile) {
+                UE_LOGW("pile_grab_test[%s #%d]: no %schipPile found -- skip", roleStr, i,
+                        std::string(roleStr) == "CLIENT" ? "BOUND " : "");
+                return;
+            }
+            // Force the aim target to the nearest pile, then fire the real E-press. lookAtActor is a
+            // per-frame line-trace field; we write it + fire on the SAME game-thread task so OnPileGrabPre
+            // (and the native grab) see our pile before the next tick re-traces. DEV/TEST only.
+            *reinterpret_cast<void**>(reinterpret_cast<uint8_t*>(player) + off) = pile;
+            UE_LOGI("pile_grab_test[%s #%d]: sim-grab nearest chipPile %p (d=%.0f cm) -- lookAtActor set, "
+                    "firing InpActEvt_use", roleStr, i, pile, d);
+            ue_wrap::ParamFrame f(fn);
+            ue_wrap::Call(player, f);
+        });
+        ::Sleep(5000);
+    }
+    UE_LOGI("pile_grab_test: %s routine complete (20 sim-grabs fired)", roleStr);
+}
