+// --- Autonomous SHADOW-DRAIN pile-resync e2e test (VOTVCOOP_RUN_PILERESYNC_TEST=1) ---------------------
+// The H-4 interaction smoke for the thin-client pile-resync DRAIN BRIDGE + the doom denominator (the CR-1/
+// CR-2 surface) -- the highest-risk new code, exercised only incidentally by the multi-reload join and never
+// asserted. It drives the SAME drain-edge logic the net_pump same-world shadow-drain fires on the CLIENT
+// (session.SendReliableToSlot(0, PileResyncRequest) + remote_prop_spawn::ArmPileDoom()), then issues a pile
+// grab DURING the re-stream window, so the full bridge runs: client requests -> host CHUNKED re-stream ->
+// PileResyncComplete{N} -> the §5 doom gate (liveMirrors==expected) fires -> the grab resolves across it.
+//
+// SCOPE / HONEST GAP (read this): the harness has NO clean way to force the ORGANIC reaper-triggered purge
+// episode (mp.py has no client-reload primitive, and the shadow-drain fires from net_pump's reaper detecting
+// a mass purge -- not callable from a worker thread). This smoke fires the drain-EDGE logic DIRECTLY, so it
+// faithfully exercises the wire round-trip + the chunked host re-stream + the doom gate, but it does NOT
+// reproduce the engine freeing the runtime mirrors first (the actual same-world drain). So it validates the
+// bridge mechanics + the denominator, NOT the "mirrors-freed-then-restored" timing. That timing still needs a
+// hands-on 2nd-reload (flagged in the report). CLIENT-driven; HOST idles (it just services the re-stream).
+// Verify in the logs:
+//   CLIENT: 'pile-resync_test: drove drain-edge -> PileResyncRequest sent + pile doom armed'
+//   HOST:   'snapshot: pile re-stream COMPLETE for slot N -- re-streamed M live pile(s) + PileResyncComplete{M}'
+//   CLIENT: 'remote_prop_spawn: PILE DOOM FIRING ... liveMirrors=N expected=N'
+//   CLIENT: a grab line ('grab CONFIRMED by clump -> PileGrabRequest relay=sent') resolving during the window
+// Never ships (env-gated). [2026-06-20 H-4, [[feedback-interaction-smoke-not-join-smoke]]]
+void RunAutonomousPileResyncTest() {
+    const std::string roleEnv = ReadEnv("VOTVCOOP_NET_ROLE");
+    if (roleEnv != "client") {
+        UE_LOGI("pile-resync_test: HOST idle (the CLIENT drives the shadow-drain edge; the host just services "
+                "the chunked re-stream -- watch for 'pile re-stream COMPLETE ... PileResyncComplete{N}')");
+        return;
+    }
+    UE_LOGI("pile-resync_test: starting on CLIENT (waiting 35 s for world + connect + connect-bracket pile doom + settle)");
+    ::Sleep(35000);
+
+    // Resolve the InpActEvt_use UFunction + lookAtActor offset once (for the grab-during-window step).
+    auto useFn   = std::make_shared<std::atomic<void*>>(nullptr);
+    auto lookOff = std::make_shared<std::atomic<int>>(-1);
+    auto rdy     = std::make_shared<std::atomic<int>>(0);
+    GT::Post([useFn, lookOff, rdy] {
+        void* cls = R::FindClass(P::name::MainPlayerClass);
+        useFn->store(cls ? R::FindFunction(cls, P::name::MainPlayerUseInputEventFn) : nullptr);
+        lookOff->store(ue_wrap::reflected_offset::MainPlayer_lookAtActor());
+        rdy->store((useFn->load() && lookOff->load() >= 0) ? 1 : 2);
+    });
+    while (rdy->load() == 0) ::Sleep(5);
+    if (rdy->load() != 1) {
+        UE_LOGW("pile-resync_test: resolve FAILED (InpActEvt_use=%p lookAtActor@%d) -- aborting",
+                useFn->load(), lookOff->load());
+        return;
+    }
+
+    // Drive the drain-edge bridge 3x (12 s apart) so a transient race doesn't hide a regression. Each cycle:
+    // (1) fire the SAME drain-edge logic net_pump's same-world shadow-drain fires; (2) ~2 s later, grab the
+    // nearest BOUND pile during the re-stream window so the grab resolves across the drain.
+    for (int cyc = 0; cyc < 3; ++cyc) {
+        // (1) drain edge: client requests a re-stream + arms the dedicated pile doom (host -> chunked re-stream
+        // -> PileResyncComplete -> the §5 doom gate fires once liveMirrors==expected).
+        GT::Post([cyc] {
+            auto* s = coop::npc_sync::GetSession();
+            if (!s || !s->connected() || s->role() != coop::net::Role::Client) {
+                UE_LOGW("pile-resync_test[#%d]: no connected CLIENT session -- skip drain edge", cyc);
+                return;
+            }
+            s->SendReliableToSlot(0, coop::net::ReliableKind::PileResyncRequest, nullptr, 0);
+            coop::remote_prop_spawn::ArmPileDoom();
+            UE_LOGI("pile-resync_test[#%d]: drove drain-edge -> PileResyncRequest sent + pile doom armed "
+                    "(host re-streams chunked; doom fires at quiescence w/ liveMirrors==expected)", cyc);
+        });
+        ::Sleep(2000);
+        // (2) grab the nearest BOUND pile DURING the re-stream window (symptom B: relay -> host clump -> adopt).
+        GT::Post([useFn, lookOff, cyc] {
+            void* player = coop::players::Registry::Get().Local();
+            if (!player || !R::IsLive(player)) return;
+            const ue_wrap::FVector pos = ue_wrap::engine::GetActorLocation(player);
+            void* pile = nullptr; float bestD2 = 30000.f * 30000.f;
+            const int32_t nObj = R::NumObjects();
+            for (int32_t k = 0; k < nObj; ++k) {
+                void* o = R::ObjectAt(k);
+                if (!o || !R::IsLive(o) || !ue_wrap::prop::IsChipPile(o)) continue;
+                const coop::element::ElementId eid = coop::remote_prop::ResolveMirrorEidByActor(o);
+                if (eid == coop::element::kInvalidId || eid == 0u || eid >= coop::element::kHostRangeSize) continue;
+                const ue_wrap::FVector l = ue_wrap::engine::GetActorLocation(o);
+                const float dx = l.X - pos.X, dy = l.Y - pos.Y, dz = l.Z - pos.Z;
+                const float dd = dx * dx + dy * dy + dz * dz;
+                if (dd < bestD2) { bestD2 = dd; pile = o; }
+            }
+            if (!pile) { UE_LOGW("pile-resync_test[#%d]: no BOUND chipPile to grab during the window -- skip", cyc); return; }
+            *reinterpret_cast<void**>(reinterpret_cast<uint8_t*>(player) + lookOff->load()) = pile;
+            UE_LOGI("pile-resync_test[#%d]: grabbing BOUND pile %p DURING the re-stream window -- firing InpActEvt_use",
+                    cyc, pile);
+            ue_wrap::ParamFrame f(useFn->load());
+            ue_wrap::Call(player, f);
+        });
+        ::Sleep(10000);  // let the chunked re-stream + the doom + the grab relay round-trip settle
+    }
+    UE_LOGI("pile-resync_test: CLIENT routine complete (3 drain-edge cycles + grabs fired)");
+}
