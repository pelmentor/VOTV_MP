-        if (!ue_wrap::prop::IsClassKeyedInteractable(cls)) continue;
-        if (!R::IsLive(obj)) continue;
-        if (R::NameStartsWith(R::NameOf(obj), L"Default__")) continue;  // CDO (alloc-free)
