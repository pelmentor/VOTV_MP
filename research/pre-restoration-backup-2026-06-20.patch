+// Within-reach CLIENT pile-grab CYCLE test -- see autotest.h. The out-of-reach sim proves the RELAY but never
+// fires the BP morph (it grabs piles 7-9 m away), so the capture -> adopt -> hold path is unverified. This
+// TELEPORTS the player next to a bound pile so the native grab does the real morph, then we read the log for the
+// adopt completing ('captured local clump' / 'adopted local clump ... onto host clumpEid'), vs a defer that never
+// resolves ('PropConvert beat the clump capture -- deferring' with no later bind = the C1 capture-miss bug).
+void RunAutonomousPileGrabReachTest() {
+    const std::string roleEnv = ReadEnv("VOTVCOOP_NET_ROLE");
+    if (roleEnv != "client") {
+        UE_LOGI("pile_grab_reach_test: HOST idle (the CLIENT drives the within-reach grab cycle)");
+        return;
+    }
+    UE_LOGI("pile_grab_reach_test: starting on CLIENT (waiting 45 s for world + connect + re-bind + pile-bind sweep)");
+    ::Sleep(45000);
+    auto useFn    = std::make_shared<std::atomic<void*>>(nullptr);
+    auto lookOff  = std::make_shared<std::atomic<int>>(-1);
+    auto resolved = std::make_shared<std::atomic<int>>(0);
+    GT::Post([useFn, lookOff, resolved] {
+        void* cls = R::FindClass(P::name::MainPlayerClass);
+        useFn->store(cls ? R::FindFunction(cls, P::name::MainPlayerUseInputEventFn) : nullptr);
+        lookOff->store(ue_wrap::reflected_offset::MainPlayer_lookAtActor());
+        resolved->store((useFn->load() && lookOff->load() >= 0) ? 1 : 2);
+    });
+    while (resolved->load() == 0) ::Sleep(5);
+    if (resolved->load() != 1) {
+        UE_LOGW("pile_grab_reach_test: resolve FAILED (InpActEvt_use=%p lookAtActor@%d) -- aborting",
+                useFn->load(), lookOff->load());
+        return;
+    }
+    UE_LOGI("pile_grab_reach_test: resolved -- teleport-grabbing the nearest BOUND chipPile within reach every 8 s x8");
+    for (int i = 0; i < 8; ++i) {
+        void* fn = useFn->load();
+        const int off = lookOff->load();
+        GT::Post([fn, off, i] {
+            void* player = coop::players::Registry::Get().Local();
+            if (!player || !R::IsLive(player)) return;
+            const ue_wrap::FVector ppos = ue_wrap::engine::GetActorLocation(player);
+            // Nearest BOUND chipPile (host-range mirror eid) = a shared host pile the client can relay.
+            void* pile = nullptr; float bestD2 = 30000.f * 30000.f;
+            const int32_t nObj = R::NumObjects();
+            for (int32_t k = 0; k < nObj; ++k) {
+                void* o = R::ObjectAt(k);
+                if (!o || !R::IsLive(o) || !ue_wrap::prop::IsChipPile(o)) continue;
+                const coop::element::ElementId eid = coop::remote_prop::ResolveMirrorEidByActor(o);
+                if (eid == coop::element::kInvalidId || eid == 0u || eid >= coop::element::kHostRangeSize) continue;
+                const ue_wrap::FVector l = ue_wrap::engine::GetActorLocation(o);
+                const float dx = l.X - ppos.X, dy = l.Y - ppos.Y, dz = l.Z - ppos.Z;
+                const float dd = dx * dx + dy * dy + dz * dz;
+                if (dd < bestD2) { bestD2 = dd; pile = o; }
+            }
+            if (!pile) { UE_LOGW("pile_grab_reach_test #%d: no BOUND chipPile found -- skip", i); return; }
+            const coop::element::ElementId eid = coop::remote_prop::ResolveMirrorEidByActor(pile);
+            const ue_wrap::FVector pl = ue_wrap::engine::GetActorLocation(pile);
+            // TELEPORT the player ~120 cm from the pile (+60 Z so it doesn't clip the ground) so the native grab
+            // is WITHIN REACH and fires the real BP pile->clump morph (the out-of-reach sim never does).
+            ue_wrap::engine::SetActorLocation(player, ue_wrap::FVector{pl.X + 120.f, pl.Y, pl.Z + 60.f});
+            *reinterpret_cast<void**>(reinterpret_cast<uint8_t*>(player) + off) = pile;
+            UE_LOGI("pile_grab_reach_test #%d: teleported player next to BOUND pile %p (eid=%u) at (%.0f,%.0f,%.0f) "
+                    "-- firing within-reach InpActEvt_use (expect morph -> capture -> adopt)",
+                    i, pile, eid, pl.X, pl.Y, pl.Z);
+            ue_wrap::ParamFrame f(fn);
+            ue_wrap::Call(player, f);
+        });
+        ::Sleep(8000);
+    }
+    UE_LOGI("pile_grab_reach_test: CLIENT routine complete (8 within-reach grabs fired)");
+}
